{
  "permissions": {
    "allow": [
      "Bash(npx --version)",
      "Bash(npx create-next-app@latest:*)",
      "Bash(cp:*)",
      "Bash(npx shadcn@latest:*)",
      "Bash(npm run:*)",
      "Bash(npm install:*)",
      "Bash(chmod +x:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(npx next:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/auto-commit.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
